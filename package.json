{
  "name": "vpnctl-mihomo",
  "version": "1.0.0",
  "description": "SSH-friendly Node.js CLI for controlling mihomo and shell proxy state",
  "type": "module",
  "bin": {
    "vpnctl": "./dist/index.js"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "start": "node ./dist/index.js tui",
    "test": "node --test --experimental-test-isolation=none"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cfonts": "^3.3.0",
    "cli-truncate": "^4.0.0",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.4",
    "@babel/preset-react": "^7.27.1"
  },
  "keywords": [
    "mihomo",
    "clash-meta",
    "vpn",
    "proxy",
    "ssh",
    "cli"
  ],
  "license": "MIT"
}
